# Environment Variables برای Railway

# Required
HERMES_HOME=/app/data
HERMES_GATEWAY=true
PORT=8080

# Provider config - به 9router وصل کن
ANTHROPIC_BASE_URL=https://9router-production-d443.up.railway.app/v1
ANTHROPIC_API_KEY=your-9router-api-key

# Optional - اگر Telegram می‌خوای
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional - اگر Discord می‌خوای  
DISCORD_BOT_TOKEN=your-discord-bot-token
